{
  "name": "ncai-design-system-temp",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "build": "turbo build",
    "changeset": "changeset",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "release": "pnpm build && pnpm smoke:pack && changeset publish",
    "storybook": "pnpm --filter @ncai/design-system-storybook-temp storybook",
    "test": "turbo test",
    "smoke:pack": "node scripts/smoke-pack.mjs",
    "typecheck": "turbo typecheck",
    "version-packages": "changeset version",
    "mcp": "pnpm --filter @ncai/design-system-mcp-temp start"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "sass": "^1.99.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vitest-axe": "^0.1.0"
  }
}
