{
  "name": "@ncai/design-tokens-temp",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./dist/styles.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GronkOut/ncai-design-system-temp.git",
    "directory": "packages/tokens"
  },
  "bugs": {
    "url": "https://github.com/GronkOut/ncai-design-system-temp/issues"
  },
  "homepage": "https://github.com/GronkOut/ncai-design-system-temp#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist --clean && sass src/styles.scss dist/styles.css --style=expanded",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  }
}
